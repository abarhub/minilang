// ── Bibliothèque standard – Boolean ──────────────────────────────────────────
//  Méthodes sur le type primitif bool.
//  Appel : b.toString(), b.and(other), etc.
//  Accessible sans import dans tout fichier minilang.

package minilang.lang;

import minilang.lang.HashCode;

class Boolean implements HashCode {

    // Retourne "true" ou "false".
    string toString() builtin;

    // Retourne true si les deux booléens sont égaux.
    bool equals(Object other) builtin;

    // Retourne la conjonction logique (this && other).
    bool and(bool other) builtin;

    // Retourne la disjonction logique (this || other).
    bool or(bool other) builtin;

    // Retourne la négation logique (!this).
    bool not() builtin;

    // Retourne le code de hachage (0 pour false, 1 pour true).
    int hashCode() builtin;
}
