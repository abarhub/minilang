// ── Bibliothèque standard – Set<T> ───────────────────────────────────────────
//  Interface pour les ensembles sans doublons.

package minilang.collection;

import minilang.collection.Iterator;

interface Set<T> {
    bool add(T element);
    bool contains(T element);
    int size();
    bool isEmpty();
    bool remove(T element);
    void clear();
    string toString();
    void forEach(fn(T) -> void consumer);
    Iterator<T> iterator();
}
