// ── Bibliothèque standard – Map<K,V> ─────────────────────────────────────────
//  Interface pour les tables associatives.

package minilang.collection;

import minilang.lang.Option;
import minilang.collection.ArrayList;

interface Map<K, V> {
    void put(K key, V value);
    Option<V> get(K key);
    bool containsKey(K key);
    int size();
    bool isEmpty();
    bool remove(K key);
    void clear();
    ArrayList<K> keys();
    string toString();
}
