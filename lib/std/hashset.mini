// ── Bibliothèque standard – HashSet<T> ───────────────────────────────────────
//  Implémentation builtin de Set<T> (unicité garantie par val_eq).

class HashSet<T> implements Set<T> {
    bool add(T element) builtin;
    bool contains(T element) builtin;
    Option<T> get(T element) builtin;
    int size() builtin;
    bool isEmpty() builtin;
    bool remove(T element) builtin;
    void clear() builtin;
    string toString() builtin;
}
