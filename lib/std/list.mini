// ── Bibliothèque standard – List<T> ──────────────────────────────────────────
//  Interface pour les listes ordonnées.

interface List<T> {
    void add(T element);
    T get(int index);
    void set(int index, T element);
    int size();
    bool isEmpty();
    bool contains(T element);
    void remove(int index);
    void clear();
    string toString();
}
